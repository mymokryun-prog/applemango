# ─── 카카오맵 (필수) ──────────────────────────────────────────────────────────
# https://developers.kakao.com 에서 앱 생성 후 JavaScript 앱 키 입력
# Koyeb 환경변수에도 동일하게 설정 필요
VITE_KAKAO_MAP_KEY=여기에_카카오_JavaScript앱키_입력

# ─── 서버 보안 (필수) ─────────────────────────────────────────────────────────
# 랜덤 32자 이상 문자열 (예: openssl rand -hex 32)
JWT_SECRET=랜덤32자이상문자열
ENCRYPTION_KEY=랜덤32자이상문자열

# ─── Gemini AI (선택 — @애망봇 채팅 기능) ─────────────────────────────────────
# https://aistudio.google.com 에서 무료 발급
GEMINI_API_KEY=

# ─── 서버 포트 (Koyeb 자동 설정) ───────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ─── VAPID (Push 알림 — 미설정 시 서버 시작 시 자동 생성) ─────────────────────────
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:your-email@example.com
